class Solution {

    public long sumAndMultiply(int n) {
        long x = 0;
        long sum = 0;
        long pow10 = 1;
        while (n > 0) {
            int d = n % 10;
            sum += d;
            if (d > 0) {
                x += d * pow10;
                pow10 *= 10;
            }
            n /= 10;
        }
        return x * sum;
    }
}
