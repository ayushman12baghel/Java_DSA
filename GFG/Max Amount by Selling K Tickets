import java.util.Arrays;

class Solution {
    static final long MOD = 1000000007L;

    public int maxAmount(int[] arr, int k) {
        Arrays.sort(arr);

        int n = arr.length;
        long ans = 0;
        long group = 1; // number of sellers at current maximum level

        for (int i = n - 1; i >= 0 && k > 0; i--, group++) {
            long cur = arr[i];
            long next = (i > 0) ? arr[i - 1] : 0;

            long diff = cur - next;
            long need = diff * group;

            if (k >= need) {
                // Sell all tickets from level cur down to next + 1
                long sumPerSeller = (cur + next + 1) * diff / 2;
                ans = (ans + (sumPerSeller % MOD) * (group % MOD)) % MOD;
                k -= need;
            } else {
                long fullLevels = k / group;
                long rem = k % group;

                long newLevel = cur - fullLevels;

                // Sell fullLevels tickets from every seller in the group
                long sumPerSeller =
                        (cur + newLevel + 1) * fullLevels / 2;
                ans = (ans + (sumPerSeller % MOD) * (group % MOD)) % MOD;

                // Sell one extra ticket from 'rem' sellers
                ans = (ans + (rem % MOD) * (newLevel % MOD)) % MOD;
                k = 0;
            }
        }

        return (int) (ans % MOD);
    }
}
